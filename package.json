{
	"name": "clean-elysia-prisma",
	"version": "1.0.50",
	"scripts": {
		"test": "echo \"Error: no test specified\" && exit 1",
		"dev": "bun run --watch src/index.ts",
		"build": "bun build \t--target bun \t--minify-whitespace \t--minify-syntax \t--outfile ./dist/index.js \tsrc/index.ts",
		"build:binary": "bun build \t--compile \t--minify-whitespace \t--minify-syntax \t--target bun \t--outfile server \tsrc/index.ts",
		"start": "bun run dist/index.js",
		"start:binary": "./server",
		"lint": "eslint . --ext .ts",
		"lint:fix": "eslint . --ext .ts --fix",
		"format": "prettier --write . --ext .ts",
		"format:check": "prettier --check . --ext .ts",
		"typechedk": "tsc --noEmit",
		"db:seed": "bun ./prisma/seed/index.ts",
		"husky": "husky install",
		"prepare": "husky"
	},
	"dependencies": {
		"@bogeychan/elysia-logger": "^0.1.10",
		"@clickhouse/client": "^1.17.0",
		"@elysiajs/bearer": "^1.4.3",
		"@elysiajs/cors": "^1.4.1",
		"@elysiajs/jwt": "^1.4.0",
		"@elysiajs/openapi": "^1.4.14",
		"@eslint/js": "^10.0.1",
		"@prisma/adapter-pg": "7.4.1",
		"@prisma/client": "7.4.1",
		"bcryptjs": "^3.0.3",
		"bullmq": "^5.70.0",
		"crypto-js": "^4.2.0",
		"dayjs": "^1.11.19",
		"dotenv": "^17.3.1",
		"elysia": "latest",
		"elysia-helmet": "^3.0.0",
		"elysia-rate-limit": "^4.5.0",
		"envalid": "^8.1.1",
		"ioredis": "^5.9.3",
		"nodemailer": "^8.0.1",
		"pg": "^8.18.0",
		"pino-pretty": "^13.1.3"
	},
	"devDependencies": {
		"@types/crypto-js": "^4.2.2",
		"@types/nodemailer": "^7.0.11",
		"@typescript-eslint/eslint-plugin": "^8.56.0",
		"@typescript-eslint/parser": "^8.56.0",
		"bun-types": "latest",
		"eslint": "^10.0.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-prettier": "^5.5.5",
		"eslint-plugin-simple-import-sort": "^12.1.1",
		"globals": "^17.3.0",
		"husky": "^9.1.7",
		"prisma": "7.4.1",
		"typescript-eslint": "^8.56.0"
	},
	"module": "src/index.js"
}
